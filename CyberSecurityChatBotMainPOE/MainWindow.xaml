<Window x:Class="CyberSecurityChatBotMainPOE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberSecurityChatBotMainPOE"
        mc:Ignorable="d"
        Title="MainWindow" Height="700" Width="1000">
    <!-- Main layout container -->
    <Grid Background="#101820">

        <!-- Grid column setup -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Grid row setup -->
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#89056c"
                Margin="10,10,10,10"
                CornerRadius="15" Grid.ColumnSpan="2">
            <StackPanel VerticalAlignment="Center">

                <!-- Main title -->
                <TextBlock Text="CYBER SECURITY BOT"
                           FontSize="30"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="White"
                />
                <!-- Subtitle -->
                <TextBlock Text="Stay Safe In The Digital World"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Foreground="White"
                />

            </StackPanel>
        </Border>
        <!-- CHAT DISPLAY AREA -->
        <ScrollViewer x:Name="ChatScrollViewer"
              Grid.Row="1"
              Margin="10,10,10,10"
              VerticalScrollBarVisibility="Auto"
              Grid.ColumnSpan="2">

            <StackPanel x:Name="ChatPanel"/>
        </ScrollViewer>

        <!-- Part 3 (POE) TASK 2: QUIZ GUI -->
       <Border x:Name="QuizPanel"
        Grid.Column="1"
        Grid.Row="1"
        Margin="5"
        Width="420"
        Height="500"
        Background="#252526"
        CornerRadius="15"
        Padding="15"
        Visibility="Collapsed">

            <StackPanel>
                <TextBlock Text="CYBERSECURITY QUIZ"
            FontSize="22"
            FontWeight="Bold"
            Foreground="White"
            HorizontalAlignment="Center"
            Margin="0,0,0,20"/>

                <Button x:Name="StartQuizButton"
            Content="Start Quiz"
            Height="35"
            Background="#89056c"
            Foreground="White"
            Click="StartQuizButton_Click"/>

                <TextBlock x:Name="FeedbackLabel" 
               Text="" 
               FontSize="14" 
               FontWeight="Bold"
               Foreground="White"          
               TextWrapping="Wrap"
               Margin="0,10"
               
               HorizontalAlignment="Center"/>

                <TextBlock x:Name="QuestionNumberLabel"
            Margin="0,20,0,5"
            Foreground="White"
            FontWeight="Bold"/>

                <TextBlock x:Name="QuestionLabel"
            TextWrapping="Wrap"
            Foreground="White"
            FontSize="16"
            Margin="0,5,0,15"/>

                <Button x:Name="AnswerAButton"
            Margin="0,3"
            Click="AnswerButton_Click"/>

                <Button x:Name="AnswerBButton"
            Margin="0,3"
            Click="AnswerButton_Click"/>

                <Button x:Name="AnswerCButton"
            Margin="0,3"
            Click="AnswerButton_Click"/>

                <Button x:Name="AnswerDButton"
            Margin="0,3"
            Click="AnswerButton_Click"/>


                <TextBlock x:Name="ScoreLabel"
            FontSize="16"
            FontWeight="Bold"
            Foreground="LightGreen"
            Margin="0,10"/>

                <Button x:Name="NextQuestionButton"
            Content="Next Question"
            Height="35"
            Visibility="Collapsed"
            Click="NextQuestionButton_Click"/>

                <Button x:Name="CloseQuizButton"
            Content="Close Quiz"
            Margin="0,10,0,0"
            Background="#89056c"
            Foreground="White"
            Click="CloseQuizButton_Click"/>

            </StackPanel>

        </Border>

        <!-- POE PART 3 TASK 1 : GUI -->
        <Border x:Name="TaskAssistantPanel"
               Grid.Column="1"
               Grid.Row="1"
               Margin="5"
               Background="#1E1E1E"
               CornerRadius="15"
               Padding="10"
               Width="380"
               Height="550">



            <DockPanel>
                <!-- HEADER (STICKY) -->
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="TASK ASSISTANT"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,10"
                       HorizontalAlignment="Center"/>

                </StackPanel>

                <!-- SCROLLABLE CONTENT -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">


                    <!-- Part 3 (POE) TASK 1: TASK ASSISTANT -->

                    <StackPanel>

                        <!-- TASK TITLE -->
                        <TextBlock Text="Task Title"
               Foreground="White"/>

                        <TextBox x:Name="TaskTitleBox"
                        Height="25"
                        Margin="0,5,0,10"/>

                        <!-- DESCRIPTION -->
                        <TextBlock Text="Description"
               Foreground="White"/>

                        <TextBox x:Name="TaskDescriptionBox"
             Height="60"
             TextWrapping="Wrap"
             AcceptsReturn="True"
             Margin="0,5,0,10"/>

                        <!-- REMINDER -->
                        <CheckBox x:Name="ReminderCheckBox"
              Content="Set Reminder"
              Foreground="White"
              Margin="0,5"/>

                        <DatePicker x:Name="ReminderDatePicker"
                Margin="0,5,0,10"/>

                        <!-- BUTTONS -->
                        <Button x:Name="AddTaskButton"
            Content="Add Task"
            Height="30"
            Margin="0,5"
            Background="#89056c"
            Foreground="White"
            Click="AddTaskButton_Click"/>

                        <Button x:Name="ViewTasksButton"
            Content="View Tasks"
            Height="30"
            Margin="0,5"
            Background="#89056c"
            Foreground="White"
            Click="ViewTasksButton_Click"/>

                        <!-- TASK DISPLAY -->
                        <ListBox x:Name="TaskListBox"
             Height="60"
             Margin="0,10,0,10"/>

                        <!-- ACTION BUTTONS -->
                        <Button x:Name="CompleteTaskButton"
            Content="Mark Completed"
            Height="35"
            Margin="0,5"
            Background="Green"
            Foreground="White"
            Click="CompleteTaskButton_Click"/>

                        <Button x:Name="DeleteTaskButton"
            Content="Delete Task"
            Height="35"
            Margin="0,5"
            Background="DarkRed"
            Foreground="White"
            Click="DeleteTaskButton_Click"/>

                        <Button x:Name="CloseTaskAssistantPanelButton"
            Content="Close Task Assistant Panel"
            Height="35"
            Margin="0,5"
            Background="#89056c"
            Foreground="White"
            Click="CloseTaskButton_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>



        <!-- POE PART 2: GUI  -->
        <!-- USER INPUT SECTION -->
        <Grid Grid.Row="2"
              Margin="10,10,10,10" 
              Grid.ColumnSpan="2">

            <!-- Input area split into textbox and button -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <!-- Input box border styling -->
            <Border Grid.Column="0"
                 CornerRadius="15"
                 Background="#EEEEEE"
                 Margin="0,0,10,0"
                 Padding="5">

                <!-- Textbox where user types messages -->
                <TextBox x:Name="UserInput"
                     FontSize="16"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="Black"
                     Height="40"
                     VerticalContentAlignment="Center"
                     KeyDown="UserInput_KeyDown"   
                />
            </Border>

            <!-- SEND button -->
            <Button Grid.Column="1"
                 Content="SEND"
                 FontSize="16"
                 FontWeight="Bold"
                 Background="#89056c"
                 Foreground="White"
                 BorderThickness="0"   
                 Click="SendButton_Click"
                 Cursor="Hand">

                <!-- Custom button styling -->
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>

                                <!-- Custom button template -->
                                <ControlTemplate TargetType="Button">

                                    <!-- Rounded button border -->
                                    <Border x:Name="border"
                                         Background="{TemplateBinding Background}"
                                         CornerRadius="15">

                                        <!-- Displays button content -->
                                        <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                        />
                                    </Border>

                                    <!-- Hover effect -->
                                    <ControlTemplate.Triggers>

                                        <!-- Changes color when mouse hovers -->
                                        <Trigger Property="IsMouseOver"
                                             Value="True">
                                            <Setter TargetName="border"
                                                 Property="Background"
                                                 Value="HotPink"
                                        />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>
